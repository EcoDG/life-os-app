# ─── Life OS 환경변수 예시 ────────────────────────────────────────────────────
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값으로 채워주세요.
# cp .env.example .env

# ─── 데이터베이스 ─────────────────────────────────────────────────────────────
# MySQL / TiDB 연결 문자열
DATABASE_URL="mysql://user:password@host:4000/dbname?ssl=true"

# ─── 인증 ─────────────────────────────────────────────────────────────────────
# JWT 세션 쿠키 서명 시크릿 (랜덤 32자 이상 문자열 권장)
JWT_SECRET="your-super-secret-jwt-key-here"

# Manus OAuth 설정 (Manus 플랫폼에서 앱 등록 후 발급)
VITE_APP_ID="your-manus-app-id"
OAUTH_SERVER_URL="https://api.manus.im"
VITE_OAUTH_PORTAL_URL="https://manus.im"

# ─── Manus 내장 API ───────────────────────────────────────────────────────────
# Manus 플랫폼의 내장 API (LLM, Storage, Notification 등)
BUILT_IN_FORGE_API_URL="https://forge.manus.im"
BUILT_IN_FORGE_API_KEY="your-built-in-forge-api-key"
VITE_FRONTEND_FORGE_API_KEY="your-frontend-forge-api-key"
VITE_FRONTEND_FORGE_API_URL="https://forge.manus.im"

# ─── 앱 설정 ──────────────────────────────────────────────────────────────────
VITE_APP_TITLE="Life OS"
VITE_APP_LOGO=""

# ─── 오너 정보 (Manus 플랫폼에서 자동 주입) ──────────────────────────────────
OWNER_OPEN_ID="your-manus-open-id"
OWNER_NAME="Your Name"

# ─── AI (Anthropic Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── 분석 (선택사항) ──────────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=""
VITE_ANALYTICS_WEBSITE_ID=""
